{
  "devDependencies": {
    "@elfalem/leaflet-curve": "^0.9.2",
    "@types/leaflet": "^1.9.21",
    "esbuild": "^0.27.3",
    "leaflet": "^1.9.4"
  },
  "scripts": {
    "build:web": "esbuild web-src/index.ts --bundle --outfile=public/dist/bundle.js --format=esm --minify --sourcemap",
